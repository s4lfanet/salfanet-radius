generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model agentSale {
  id            String   @id
  agentId       String
  voucherCode   String
  profileName   String
  amount        Int
  createdAt     DateTime @default(now())
  paymentStatus String   @default("UNPAID") // UNPAID, PAID
  paymentDate   DateTime?
  paymentMethod String?  // CASH, TRANSFER, etc
  paymentNote   String?  @db.Text
  paidAmount    Int      @default(0)
  agents        agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId])
  @@index([createdAt])
  @@index([paymentStatus])
  @@map("agent_sales")
}

model agentDeposit {
  id              String   @id
  agentId         String
  amount          Int
  status          String   @default("PENDING") // PENDING, PAID, EXPIRED, FAILED
  paymentGateway  String?  // midtrans, xendit, duitku
  paymentToken    String?  @unique
  paymentUrl      String?  @db.Text
  transactionId   String?
  paidAt          DateTime?
  expiredAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  agent           agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId])
  @@index([status])
  @@index([paymentToken])
  @@map("agent_deposits")
}

model agent {
  id          String               @id
  name        String
  phone       String               @unique
  email       String?
  address     String?
  isActive    Boolean              @default(true)
  balance     Int                  @default(0)     // Saldo agent untuk generate voucher
  minBalance  Int                  @default(0)     // Min saldo untuk generate voucher
  routerId    String?              // Router/NAS yang ditangani agent ini
  router      router?              @relation(fields: [routerId], references: [id], onDelete: SetNull)
  lastLogin   DateTime?            // Waktu login terakhir agent
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  sales       agentSale[]
  deposits    agentDeposit[]
  vouchers    hotspotVoucher[]
  notifications agentNotification[]

  @@index([phone])
  @@index([routerId])
  @@map("agents")
}

model company {
  id                   String   @id
  name                 String
  address              String?
  phone                String?
  email                String?
  logo                 String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  adminPhone           String?
  baseUrl              String?  @default("http://localhost:3000")
  timezone             String?  @default("Asia/Jakarta")
  bankAccounts         Json?    // Array of bank account objects: [{bankName, accountNumber, accountName}]
  poweredBy            String?  @default("SALFANET RADIUS")
  
  // Footer settings for different portals
  footerAdmin          String?  @db.Text // Footer for admin login page
  footerCustomer       String?  @db.Text // Footer for customer login page
  footerTechnician     String?  @db.Text // Footer for technician login page
  
  invoiceGenerateDays  Int?     @default(7) // Days before expiry to generate invoice
  gracePeriodDays      Int?     @default(0) // Grace period days after expiry user can still online

  // Isolation settings
  isolationEnabled             Boolean? @default(true) // Enable/disable auto isolation
  isolationIpPool              String?  @default("192.168.200.0/24") @db.VarChar(100) // IP pool for isolated users
  isolationServerIp            String?  @db.VarChar(100) // VPS/billing server IP for MikroTik NAT redirect (must be IP, not hostname)
  isolationRateLimit           String?  @default("64k/64k") @db.VarChar(50) // Rate limit for isolated users
  isolationRedirectUrl         String?  @db.Text // URL to redirect isolated users
  isolationMessage             String?  @db.Text // Custom message for isolated users (deprecated - use templates)
  isolationAllowDns            Boolean? @default(true) // Allow DNS for isolated users
  isolationAllowPayment        Boolean? @default(true) // Allow access to payment page
  isolationNotifyWhatsapp      Boolean? @default(true) // Send WhatsApp notification when isolated
  isolationNotifyEmail         Boolean? @default(false) // Send Email notification when isolated
  isolationWhatsappTemplateId  String?  @db.VarChar(191) // WhatsApp template ID
  isolationEmailTemplateId     String?  @db.VarChar(191) // Email template ID
  isolationHtmlTemplateId      String?  @db.VarChar(191) // HTML page template ID

  // PPPoE Renewal settings
  pppoeRenewalAnytime          Boolean? @default(false) // Allow renewal anytime
  pppoeRenewalDaysBefore       Int?     @default(7) // Days before expiry to allow renewal

  // Referral system settings
  referralEnabled              Boolean? @default(false) // Enable/disable referral system
  referralRewardAmount         Int?     @default(10000) // Reward amount (IDR) for referrer
  referralRewardType           String?  @default("FIRST_PAYMENT") // REGISTRATION or FIRST_PAYMENT
  referralRewardBoth           Boolean? @default(false) // Also reward the referred customer
  referralReferredAmount       Int?     @default(0) // Reward amount for referred customer

  @@map("companies")
}

model isolationTemplate {
  id         String   @id
  type       isolationTemplate_type
  name       String   @db.VarChar(255)
  subject    String?  @db.VarChar(500) // Email subject only
  message    String   @db.Text
  variables  Json?    // Available variables for this template
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([type])
  @@index([isActive])
  @@map("isolation_templates")
}

enum isolationTemplate_type {
  whatsapp
  email
  html_page
}

model hotspotProfile {
  id                  String                        @id
  name                String                        @unique
  sharedUsers         Int                           @default(1)
  createdAt           DateTime                      @default(now())
  updatedAt           DateTime                      @updatedAt
  agentAccess         Boolean                       @default(true)
  costPrice           Int
  eVoucherAccess      Boolean                       @default(true)
  groupProfile        String?
  isActive            Boolean                       @default(true)
  resellerFee         Int                           @default(0)
  sellingPrice        Int
  speed               String
  validityUnit        hotspot_profiles_validityUnit
  validityValue       Int
  usageQuota          BigInt?                       // Kuota data dalam bytes (null = unlimited)
  usageDuration       Int?                          // Durasi penggunaan (null = unlimited)
  usageDurationUnit   hotspot_profiles_validityUnit @default(HOURS) // Unit durasi: MINUTES, HOURS, DAYS
  vouchers            hotspotVoucher[]
  orders              voucherOrder[]

  @@map("hotspot_profiles")
}

model hotspotVoucher {
  id           String                  @id
  code         String                  @unique
  password     String?                 // Separate password for username != password mode
  profileId    String
  routerId     String?                 // Router/NAS that this voucher belongs to
  agentId      String?                 // Agent who created/owns this voucher
  voucherType  String                  @default("same") // "same" = username=password, "different" = separate password
  codeType     String                  @default("alphanumeric") // Code combination type
  status       hotspot_vouchers_status @default(WAITING)
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  batchCode    String?
  expiresAt    DateTime?
  firstLoginAt DateTime?
  lastUsedBy   String?
  orderId      String?
  order        voucherOrder?           @relation(fields: [orderId], references: [id])
  profile      hotspotProfile          @relation(fields: [profileId], references: [id])
  router       router?                 @relation(fields: [routerId], references: [id])
  agent        agent?                  @relation(fields: [agentId], references: [id])

  @@index([batchCode])
  @@index([orderId])
  @@index([profileId], map: "hotspot_vouchers_profileId_fkey")
  @@index([routerId])
  @@index([agentId])
  @@index([status])
  @@map("hotspot_vouchers")
}

model invoice {
  id               String          @id
  invoiceNumber    String          @unique
  userId           String?
  amount           Int
  status           invoices_status @default(PENDING)
  dueDate          DateTime
  paidAt           DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  paymentLink      String?
  paymentToken     String?         @unique
  customerName     String?
  customerPhone    String?
  customerEmail    String?         // Customer email for email reminders
  customerUsername String?
  sentReminders    String?         @db.Text // JSON array of sent reminder days, e.g., "[-7, -5, -3]"
  
  // Notes / catatan internal admin
  notes            String?         @db.Text
  
  // NEW: Invoice type and tax fields
  invoiceType      InvoiceType     @default(MONTHLY)
  baseAmount       Int?            // Amount before tax
  taxRate          Decimal?        @db.Decimal(5,2) // Tax percentage
  additionalFees   Json?           // [{name: string, amount: number}]
  
  user             pppoeUser?           @relation(fields: [userId], references: [id])
  payments         payment[]
  manualPayments   manualPayment[]
  registration     registrationRequest?

  @@index([userId], map: "invoices_userId_fkey")
  @@index([status])
  @@index([dueDate])
  @@index([invoiceType])
  @@map("invoices")
}

enum InvoiceType {
  MONTHLY      // Tagihan bulanan regular
  INSTALLATION // Biaya pemasangan
  ADDON        // Biaya tambahan
  TOPUP        // Top up saldo (prepaid)
  RENEWAL      // Perpanjangan (prepaid)
}

model vpnServer {
  id             String      @id @default(uuid())
  name           String
  host           String
  username       String
  password       String
  apiPort        Int         @default(8728)
  subnet         String
  l2tpEnabled    Boolean     @default(false)
  sstpEnabled    Boolean     @default(false)
  pptpEnabled    Boolean     @default(false)
  wgEnabled      Boolean     @default(false)
  wgPublicKey    String?     @db.Text
  wgPort         Int?        @default(51820)
  openVpnEnabled Boolean     @default(false)
  openVpnPort    Int?        @default(1194)
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  vpnClients     vpnClient[]

  @@map("vpn_servers")
}

model vpnClient {
  id               String     @id @default(uuid())
  name             String
  vpnServerId      String
  vpnIp            String
  username         String     @unique
  password         String
  vpnType          String     @default("L2TP")
  description      String?    @db.Text
  winboxPort       Int?
  apiUsername      String?
  apiPassword      String?
  clientPublicKey  String?    @db.Text
  clientPrivateKey String?    @db.Text
  isActive         Boolean    @default(true)
  isRadiusServer   Boolean    @default(false)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  vpnServer        vpnServer  @relation(fields: [vpnServerId], references: [id], onDelete: Cascade)
  routers          router[]

  @@unique([vpnServerId, vpnIp])
  @@map("vpn_clients")
}

model router {
  id             String             @id
  name           String
  nasname        String             // NAS IP Address (can be same for multiple NAS with different ports)
  shortname      String
  type           String             @default("mikrotik")
  ipAddress      String
  username       String
  password       String
  port           Int                @default(8728)
  apiPort        Int                @default(8729)
  secret         String             @default("secret123")
  ports          Int                @default(1812)
  server         String?
  community      String?
  description    String?
  latitude       Float?             // GPS latitude for map display
  longitude      Float?             // GPS longitude for map display
  vpnClientId    String?            // Optional: Connect via VPN Client
  isActive       Boolean            @default(true)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  users          pppoeUser[]
  networkServers networkServer[]
  vouchers       hotspotVoucher[]
  agents         agent[]            // Agents assigned to this router
  oltRouters     networkOLTRouter[] // OLT router assignments
  vpnClient      vpnClient?         @relation(fields: [vpnClientId], references: [id], onDelete: SetNull)

  @@unique([nasname, ports, secret]) // Allow same IP with different port/secret
  @@index([nasname])
  @@index([shortname])
  @@index([vpnClientId])
  @@map("nas")
}

model paymentGateway {
  id                  String       @id
  name                String
  isActive            Boolean      @default(false)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  midtransClientKey   String?
  midtransEnvironment String       @default("sandbox")
  midtransServerKey   String?
  provider            String       @unique
  xenditApiKey        String?
  xenditEnvironment   String       @default("sandbox")
  xenditWebhookToken  String?
  duitkuMerchantCode  String?
  duitkuApiKey        String?  // API Key untuk signature
  duitkuEnvironment   String       @default("sandbox")
  tripayMerchantCode  String?
  tripayApiKey        String?
  tripayPrivateKey    String?
  tripayEnvironment   String       @default("sandbox")
  payments            payment[]
  logs                webhookLog[]

  @@map("payment_gateways")
}

model payment {
  id      String          @id
  invoiceId String
  amount  Int
  method  String
  gatewayId String?
  status  String
  notes   String?         @db.Text
  paidAt  DateTime        @default(now())
  createdAt DateTime      @default(now())
  gateway paymentGateway? @relation(fields: [gatewayId], references: [id])
  invoice invoice         @relation(fields: [invoiceId], references: [id])

  @@index([gatewayId], map: "payments_gatewayId_fkey")
  @@index([invoiceId], map: "payments_invoiceId_fkey")
  @@map("payments")
}

model registrationRequest {
  id              String    @id
  name            String
  phone           String    @unique
  email           String?
  latitude        Float?
  longitude       Float?
  address         String
  profileId       String
  installationFee Decimal   @default(0) @db.Decimal(10, 2)
  notes           String?   @db.Text
  referralCode    String?   @db.VarChar(10) // Referral code used during registration
  idCardNumber    String?   @db.VarChar(20)
  idCardPhoto     String?   @db.Text
  status          String    @default("PENDING")
  rejectionReason String?   @db.Text
  invoiceId       String?   @unique
  pppoeUserId     String?   @unique
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  profile         pppoeProfile @relation(fields: [profileId], references: [id])
  invoice         invoice?     @relation(fields: [invoiceId], references: [id])
  pppoeUser       pppoeUser?   @relation(fields: [pppoeUserId], references: [id])

  @@index([profileId])
  @@index([status])
  @@index([phone])
  @@map("registration_requests")
}

model pppoeProfile {
  id             String                      @id
  name           String                      @unique
  price          Int
  createdAt      DateTime                    @default(now())
  updatedAt      DateTime                    @updatedAt
  description    String?
  downloadSpeed  Int
  uploadSpeed    Int
  rateLimit      String?                     // Store complex MikroTik rate limit formats
  groupName      String
  isActive       Boolean                     @default(true)
  lastSyncAt     DateTime?
  syncedToRadius Boolean                     @default(false)
  validityUnit   pppoe_profiles_validityUnit @default(MONTHS)
  validityValue  Int                         @default(1)
  sharedUser     Boolean                     @default(true) // Only one device per username
  users          pppoeUser[]
  registrations  registrationRequest[]

  @@index([groupName])
  @@map("pppoe_profiles")
}

model pppoeArea {
  id          String      @id
  name        String      @unique
  description String?
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  users       pppoeUser[]

  @@map("pppoe_areas")
}

model pppoeUser {
  id               String         @id
  username         String         @unique
  customerId       String?        @unique @map("customer_id") @db.VarChar(8)
  password         String
  profileId        String
  areaId           String?
  status           String         @default("active")
  ipAddress        String?
  macAddress       String?
  comment          String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  expiredAt        DateTime?      // PREPAID: expiry date, POSTPAID: null
  address          String?
  latitude         Float?
  longitude        Float?
  email            String?
  lastSyncAt       DateTime?
  name             String
  phone            String
  syncedToRadius   Boolean        @default(false)
  routerId         String?
  subscriptionType SubscriptionType @default(POSTPAID)
  lastPaymentDate  DateTime?
  
  // NEW: Billing configuration fields
  billingDay           Int?       @default(1) // 1-31, untuk POSTPAID (default: tanggal 1)
  autoIsolationEnabled Boolean    @default(true) // Allow auto isolation
  balance              Int        @default(0) // Saldo deposit (prepaid)
  autoRenewal          Boolean    @default(false) // Auto renew from balance
  connectionType       ConnectionType @default(PPPOE)
  fcmTokens            String?    @db.Text // FCM tokens for push notifications (JSON array)

  // Customer document & installation fields (from billing-radius)
  idCardNumber         String?    @db.VarChar(50) // NIK KTP
  idCardPhoto          String?    @db.VarChar(500) // URL foto KTP
  installationPhotos   Json?      // Array of installation photo URLs
  followRoad           Boolean    @default(false) // Garis ke ODP ikuti jalanan

  // Referral system fields
  referralCode         String?    @unique @db.VarChar(10) // Auto-generated referral code
  referredById         String?    @map("referred_by_id") // ID of user who referred this customer
  
  invoices         invoice[]
  manualPayments   manualPayment[]
  tickets          ticket[]
  profile          pppoeProfile   @relation(fields: [profileId], references: [id])
  area             pppoeArea?     @relation(fields: [areaId], references: [id])
  router           router?        @relation(fields: [routerId], references: [id])
  sessions         sessions[]
  registration     registrationRequest?
  odpAssignment    odpCustomerAssignment?
  suspendRequests  suspendRequest[]
  referredBy       pppoeUser?     @relation("Referrals", fields: [referredById], references: [id], onDelete: SetNull)
  referrals        pppoeUser[]    @relation("Referrals") // Users referred by this customer
  referralRewardsGiven    referralReward[] @relation("ReferrerRewards")
  referralRewardsReceived referralReward[] @relation("ReferredRewards")

  @@index([profileId], map: "pppoe_users_profileId_fkey")
  @@index([routerId], map: "pppoe_users_routerId_fkey")
  @@index([areaId])
  @@index([status])
  @@index([username])
  @@index([subscriptionType])
  @@index([billingDay])
  @@index([autoRenewal])
  @@index([referralCode])
  @@index([referredById])
  // Performance indexes: common lookup patterns
  @@index([phone])               // customer login by phone number
  @@index([expiredAt])           // cron auto-isolate expired users
  @@index([status, expiredAt])   // composite: filter active+expired users
  @@map("pppoe_users")
}

enum ConnectionType {
  PPPOE
  HOTSPOT
  STATIC_IP
}

model radacct {
  radacctid           BigInt    @id @default(autoincrement())
  acctsessionid       String    @db.VarChar(64)
  acctuniqueid        String    @unique @db.VarChar(32)
  username            String    @db.VarChar(64)
  groupname           String    @default("") @db.VarChar(64)
  realm               String?   @db.VarChar(64)
  nasipaddress        String    @db.VarChar(15)
  nasportid           String?   @db.VarChar(32)
  nasporttype         String?   @db.VarChar(32)
  acctstarttime       DateTime?
  acctupdatetime      DateTime?
  acctstoptime        DateTime?
  acctinterval        Int?
  acctsessiontime     Int?      @db.UnsignedInt
  acctauthentic       String?   @db.VarChar(32)
  connectinfo_start   String?   @db.VarChar(50)
  connectinfo_stop    String?   @db.VarChar(50)
  acctinputoctets     BigInt?
  acctoutputoctets    BigInt?
  calledstationid     String    @db.VarChar(50)
  callingstationid    String    @db.VarChar(50)
  acctterminatecause  String    @db.VarChar(32)
  servicetype         String?   @db.VarChar(32)
  framedprotocol      String?   @db.VarChar(32)
  framedipaddress     String    @db.VarChar(15)
  framedipv6address   String    @default("") @db.VarChar(45)
  framedipv6prefix    String    @default("") @db.VarChar(45)
  framedinterfaceid   String    @default("") @db.VarChar(44)
  delegatedipv6prefix String    @default("") @db.VarChar(45)

  @@index([acctinterval])
  @@index([acctsessionid])
  @@index([acctsessiontime])
  @@index([acctstarttime])
  @@index([acctstoptime])
  @@index([framedipaddress])
  @@index([nasipaddress])
  @@index([username])
  // Composite indexes untuk query paling sering digunakan
  @@index([username, acctstoptime])         // active session per user: WHERE username=? AND acctstoptime IS NULL
  @@index([acctstoptime, acctupdatetime])   // online user count: WHERE acctstoptime IS NULL AND acctupdatetime >= ?
}

model radcheck {
  id        Int    @id @default(autoincrement())
  username  String @db.VarChar(64)
  attribute String @db.VarChar(64)
  op        String @default(":=") @db.Char(2)
  value     String @db.VarChar(253)

  @@unique([username, attribute])
  @@index([username])
}

model radgroupcheck {
  id        Int    @id @default(autoincrement()) @db.UnsignedInt
  groupname String @db.VarChar(64)
  attribute String @db.VarChar(64)
  op        String @default("==") @db.Char(2)
  value     String @db.VarChar(253)

  @@index([groupname])
}

model radgroupreply {
  id        Int    @id @default(autoincrement())
  groupname String @db.VarChar(64)
  attribute String @db.VarChar(64)
  op        String @default(":=") @db.Char(2)
  value     String @db.VarChar(253)

  @@index([groupname])
}

model radpostauth {
  id       Int      @id @default(autoincrement())
  username String   @db.VarChar(64)
  pass     String   @db.VarChar(64)
  reply    String   @db.VarChar(32)
  authdate DateTime @default(now())

  @@index([authdate])
  @@index([username])
  // Composite: auth log per user sorted by date (admin panel)
  @@index([username, authdate])
}

model radreply {
  id        Int    @id @default(autoincrement()) @db.UnsignedInt
  username  String @db.VarChar(64)
  attribute String @db.VarChar(64)
  op        String @default("=") @db.Char(2)
  value     String @db.VarChar(253)

  @@index([username])
}

model radusergroup {
  id        Int    @id @default(autoincrement())
  username  String @db.VarChar(64)
  groupname String @db.VarChar(64)
  priority  Int    @default(1)

  @@unique([username, groupname])
  @@index([groupname])
  @@index([username])
}

model sessions {
  id            String      @id
  username      String
  userId        String?
  nasIpAddress  String
  sessionId     String      @unique
  startTime     DateTime    @default(now())
  stopTime      DateTime?
  uploadBytes   BigInt      @default(0)
  downloadBytes BigInt      @default(0)
  createdAt     DateTime    @default(now())
  user          pppoeUser?  @relation(fields: [userId], references: [id])

  @@index([userId], map: "sessions_userId_fkey")
}

model users {
  id        String     @id
  email     String     @unique
  password  String
  name      String
  role      users_role @default(ADMIN)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model voucherOrder {
  id        String                @id
  orderNumber String              @unique
  profileId String
  quantity  Int                   @default(1)
  customerName String
  customerPhone String
  customerEmail String?
  totalAmount Int
  status    voucher_orders_status @default(PENDING)
  paymentToken String?             @unique
  paymentLink String?
  paidAt    DateTime?
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt
  vouchers  hotspotVoucher[]
  profile   hotspotProfile        @relation(fields: [profileId], references: [id])

  @@index([orderNumber])
  @@index([profileId], map: "voucher_orders_profileId_fkey")
  @@index([status])
  @@map("voucher_orders")
}

model voucherTemplate {
  id           String   @id
  name         String
  htmlTemplate String   @db.Text
  isDefault    Boolean  @default(false)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("voucher_templates")
}

model webhookLog {
  id            String          @id
  gateway       String
  gatewayId     String?
  orderId       String
  status        String
  transactionId String?
  amount        Int?
  payload       String?         @db.Text
  response      String?         @db.Text
  success       Boolean         @default(true)
  errorMessage  String?         @db.Text
  createdAt     DateTime        @default(now())
  paymentGateway paymentGateway? @relation(fields: [gatewayId], references: [id])

  @@index([createdAt])
  @@index([gatewayId], map: "webhook_logs_gatewayId_fkey")
  @@index([gateway])
  @@index([orderId])
  @@map("webhook_logs")
}

model whatsapp_history {
  id           String   @id
  phone        String
  message      String   @db.Text
  status       String
  response     String?  @db.Text
  providerName String?
  providerType String?
  sentAt       DateTime @default(now())
}

